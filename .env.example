# ─── TES Pro Backend — Environment Variables ───────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to GitHub.

# Paystack secret key (from dashboard.paystack.com → Settings → API Keys)
# sk_test_ → test mode (no real charges)
# sk_live_ → live mode (real charges)
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here

# FRED API key (free — get at fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# NewsAPI key (free — get at newsapi.org/register)
NEWS_API_KEY=your_newsapi_key_here

# Your GitHub Pages domain (and any other allowed frontend origins)
# Comma-separated, no trailing slashes
ALLOWED_ORIGINS=https://yourusername.github.io,https://your-custom-domain.com

# Port (Render sets this automatically — leave as 3001 for local dev)
PORT=3001
